+bool shouldLogTableScanPool(const memory::MemoryPool* pool);
+
+std::mutex& tableScanPoolThreadOwnersMutex() {
+  static std::mutex mutex;
+  return mutex;
+}
+
+auto& tableScanPoolThreadOwners() {
+  static std::unordered_map<std::string, std::unordered_map<std::string, int32_t>>
+      owners;
+  return owners;
+}
+
+std::string currentThreadLabel() {
+  std::ostringstream out;
+  out << "tid=" << std::this_thread::get_id();
+  return out.str();
+}
+
+std::string formatThreadOwnersLocked(std::string_view poolName) {
+  const auto poolIt = tableScanPoolThreadOwners().find(std::string(poolName));
+  if (poolIt == tableScanPoolThreadOwners().end() || poolIt->second.empty()) {
+    return "[]";
+  }
+
+  std::ostringstream out;
+  out << "[";
+  bool first = true;
+  for (const auto& [threadName, count] : poolIt->second) {
+    if (!first) {
+      out << ", ";
+    }
+    first = false;
+    out << threadName << ":" << count;
+  }
+  out << "]";
+  return out.str();
+}
+
+void trackAsyncLoadHolderRefChange(
+    const char* where,
+    const std::shared_ptr<memory::MemoryPool>& pool,
+    std::string_view threadName,
+    int32_t delta) {
+  if (!shouldLogTableScanPool(pool.get())) {
+    return;
+  }
+
+  std::string owners;
+  {
+    std::lock_guard<std::mutex> lock(tableScanPoolThreadOwnersMutex());
+    auto& poolOwners = tableScanPoolThreadOwners()[pool->name()];
+    auto& count = poolOwners[std::string(threadName)];
+    count += delta;
+    if (count <= 0) {
+      poolOwners.erase(std::string(threadName));
+    }
+    if (poolOwners.empty()) {
+      tableScanPoolThreadOwners().erase(pool->name());
+    }
+    owners = formatThreadOwnersLocked(pool->name());
+  }
+
+  LOG(WARNING) << where << " pool=" << pool->name()
+               << " poolUseCount=" << pool.use_count()
+               << " delta=" << delta
+               << " thread=" << threadName
+               << " ownerThreads=" << owners;
+}
+
+bool shouldLogTableScanPool(const memory::MemoryPool* pool) {
+  return pool != nullptr &&
+      pool->name().find("TableScan#tspool") != std::string::npos;
+}
+
+} // namespace
+
+void debugTrackAsyncLoadHolderRefDecrement(
+    const std::shared_ptr<memory::MemoryPool>& pool) {
+  trackAsyncLoadHolderRefChange(
+      "AsyncLoadHolder pool ref decrement", pool, currentThreadLabel(), -1);
+}
+
+void debugTrackAsyncLoadHolderRefChangeForThread(
+    const char* where,
+    const std::shared_ptr<memory::MemoryPool>& pool,
+    std::string_view threadName,
+    int32_t delta) {
+  trackAsyncLoadHolderRefChange(where, pool, threadName, delta);
+}
+
+DirectBufferedInput::AsyncLoadHolder::AsyncLoadHolder(
+    std::shared_ptr<cache::CoalescedLoad> load,
+    std::shared_ptr<memory::MemoryPool> pool)
+    : load(std::move(load)),
+      pool(std::move(pool)),
+      ownerThread(currentThreadLabel()) {
+  if (this->pool != nullptr) {
+    debugTrackAsyncLoadHolderRefChangeForThread(
+        "AsyncLoadHolder pool ref increment",
+        this->pool,
+        ownerThread,
+        1);
+  }
+}
+
+DirectBufferedInput::AsyncLoadHolder::AsyncLoadHolder(
+    AsyncLoadHolder&& other) noexcept
+    : load(std::move(other.load)),
+      pool(std::move(other.pool)),
+      ownerThread(currentThreadLabel()) {
+  if (pool != nullptr) {
+    debugTrackAsyncLoadHolderRefChangeForThread(
+        "AsyncLoadHolder pool ref decrement", pool, other.ownerThread, -1);
+    debugTrackAsyncLoadHolderRefChangeForThread(
+        "AsyncLoadHolder pool ref increment", pool, ownerThread, 1);
+  }
+  other.ownerThread.clear();
+}
+
+DirectBufferedInput::AsyncLoadHolder::~AsyncLoadHolder() {
+  // Release the load reference before the memory pool reference.
+  // This is to make sure the memory pool is not destroyed before we free up
+  // the allocated buffers.
+  // This is to handle the case that the associated task has already
+  // destroyed before the async load is done. The async load holds
+  // the last reference to the memory pool in that case.
+  load.reset();
+  if (pool != nullptr) {
+    debugTrackAsyncLoadHolderRefChangeForThread(
+        "AsyncLoadHolder pool ref decrement", pool, ownerThread, -1);
+  }
+  pool.reset();
+}
